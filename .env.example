# Waitlist storage (optional in dev, required to persist in production).
#
# The /api/subscribe route stores emails in Vercel KV / Upstash Redis when these
# are set. Create a free KV store in the Vercel dashboard (Storage > KV) or an
# Upstash Redis database, then copy its REST URL + token here.
#
# With nothing set, dev writes signups to .data/subscribers.jsonl; production
# logs a warning and does not persist (so wire this up before launch).

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash's own variable names are also accepted as a fallback:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
